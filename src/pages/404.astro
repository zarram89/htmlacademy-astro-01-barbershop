---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Страница не найдена — Барбершоп «Бородинский»" noindex={true}>
  <div class="page-container">
    <div class="not-found">
      <h1 class="not-found-code">404</h1>
      <p class="not-found-text">Такой страницы нет</p>
      <p class="not-found-description">
        Возможно, она была удалена или вы перешли по неверной ссылке.
      </p>
      <a class="button button-all" href="/">На главную</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80px 0;
    text-align: center;
  }

  .not-found-code {
    margin: 0;
    margin-bottom: 16px;
    font-family: var(--font-family-heading);
    font-size: 120px;
    line-height: 1;
    color: #814b18;
    text-transform: uppercase;
  }

  .not-found-text {
    margin-bottom: 8px;
    font-family: var(--font-family-heading);
    font-size: 32px;
    line-height: 35px;
    text-transform: uppercase;
    color: #000000;
  }

  .not-found-description {
    margin-bottom: 32px;
    font-size: 16px;
    line-height: 24px;
    color: #595959;
  }
</style>
