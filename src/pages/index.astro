---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="hero">
    <div class="hero__inner">
      <h1 class="hero__title">Барбершоп «Бородинский»</h1>
      <p class="hero__slogan">Профессиональное мужское пространство в центре Санкт-Петербурга</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 80px 20px;
    text-align: center;
    background-color: var(--color-gray-100);
  }

  .hero__title {
    font-family: var(--font-family-heading);
    font-size: 48px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .hero__slogan {
    font-size: 18px;
    color: var(--color-gray-500);
    max-width: 600px;
    margin: 0 auto;
  }
</style>
